{
  "name": "streaming-lists",
  "version": "2.0.0",
  "engines": {
    "node": "24.x",
    "npm": "11.12.1"
  },
  "scripts": {
    "ng": "ng",
    "start": "node dist/server/main.js",
    "start:heroku": "node dist/server/main.js",
    "heroku-postbuild": "npm run build:ssr",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "dev:ssr": "node --no-deprecation ./node_modules/@angular/cli/bin/ng.js run streaming-lists:serve-ssr",
    "serve:ssr": "node dist/server/main.js",
    "build:ssr": "ng build --configuration production && ng run streaming-lists:server:production",
    "prerender": "ng run streaming-lists:prerender"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.7",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-browser-dynamic": "^22.0.7",
    "@angular/platform-server": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/service-worker": "^22.0.7",
    "@angular/ssr": "^22.0.7",
    "express": "^4.17.1",
    "rxjs": "~6.5.4",
    "tslib": "^2.0.0",
    "xmlhttprequest": "^1.8.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@angular/language-service": "^22.0.7",
    "@types/express": "^4.17.13",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^24.12.0",
    "@types/qs": "6.9.6",
    "browser-sync": "^3.0.0",
    "codelyzer": "^6.0.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.5.0",
    "protractor": "~7.0.0",
    "ts-node": "^8.3.0",
    "tslint": "~6.1.0",
    "typescript": "~6.0.3"
  }
}
